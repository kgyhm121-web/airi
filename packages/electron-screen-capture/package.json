{
  "name": "@proj-airi/electron-screen-capture",
  "type": "module",
  "version": "0.8.4",
  "private": true,
  "description": "Screen capture",
  "author": {
    "name": "Moeru AI Project AIRI Team",
    "email": "airi@moeru.ai",
    "url": "https://github.com/moeru-ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
